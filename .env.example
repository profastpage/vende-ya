# =====================================================================
# VENDE YA — Environment Variables (example)
# =====================================================================
# Copy this file to .env.local for local dev, and set the same vars
# in Vercel Project Settings → Environment Variables for production.
# =====================================================================

# ---- Database (Prisma) ----
# Local dev: SQLite file (auto-created on `bun run db:push`)
DATABASE_URL="file:./db/custom.db"
# Production (Vercel): use Supabase Postgres pooler URL
# DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# ---- Supabase (production auth + realtime) ----
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Cloudflare Stream (live video) ----
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""
CLOUDFLARE_STREAM_SIGNING_KEY=""

# ---- Cloudflare R2 (object storage) ----
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="vendeya"
CLOUDFLARE_R2_ACCOUNT_ID=""

# ---- AI Edge (z-ai-web-dev-sdk) ----
# Already configured via the SDK in this sandbox.
# In production, set the equivalent keys for DeepSeek / Qwen routing.
ZAI_API_KEY=""

# ---- Realtime (Socket.io mini-service) ----
# In dev: socket.io runs on port 3003 (see mini-services/auction-realtime)
# In prod: deploy the mini-service to Render / Fly / Railway and set:
NEXT_PUBLIC_REALTIME_URL=""

# ---- App ----
NEXT_PUBLIC_APP_NAME="Vende Ya"
NEXT_PUBLIC_DEFAULT_LOCALE="es-PE"
NEXT_PUBLIC_DEFAULT_CURRENCY="PEN"

# ---- Web Push (VAPID keys) ----
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@vendeya.pe"
