# =====================================================================
# VENDE YA — .gitignore
# =====================================================================

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
bun.lockb

# testing
/coverage

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env
.env.*
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# database (SQLite dev only — use Supabase Postgres in prod)
/db/
*.db
*.db-journal
*.sqlite
*.sqlite3

# logs
*.log
dev.log
dev.out.log
server.log
auction-realtime.log
mini-service-*.log

# sandbox / runtime artifacts
local-*
.claude
.z-ai-config
.zscripts/
prompt
test

# skills directory (internal)
/skills/

# screenshots / scripts scratch
/scripts/screenshot-*.png
/scripts/final-*.png
/scripts/*.webm

# editor
.vscode/
.idea/
*.swp
*.swo

# os
.DS_Store
Trashes
ehthumbs.db
